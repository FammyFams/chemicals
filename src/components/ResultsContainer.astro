<section id="results" class="hidden">
  <div class="banner">
    Percentages shown as <strong>Estimated %</strong> are approximations. SDS sheets disclose ranges
    (not exact values), and trade-secret ingredients are withheld — estimates assume all components total ~100%.
  </div>

  <div class="panel">
    <h2 style="margin-top:0;font-size:1.1rem">Composition</h2>
    <div id="bar" class="bar"></div>
    <div id="legend" class="legend"></div>

    <table>
      <thead>
        <tr>
          <th>Chemical</th>
          <th>CAS&nbsp;No.</th>
          <th>Disclosed range</th>
          <th class="num">Estimated %</th>
        </tr>
      </thead>
      <tbody id="rows"></tbody>
    </table>
  </div>
</section>
