---
import Layout from '../layouts/Layout.astro';
import InputPanel from '../components/InputPanel.astro';
import ResultsContainer from '../components/ResultsContainer.astro';
---

<Layout>
  <InputPanel />
  <ResultsContainer />
</Layout>

<script>
  import { extractLines } from '../lib/pdf';
  import { parseSds } from '../lib/sds';
  import { resolveToPdf } from '../lib/source';
  import productsRaw from '../data/products.json';
  import type { Ingredient } from '../lib/types';

  interface Product {
    name: string; slug: string; brand?: string; aliases?: string[];
    sourceUrl?: string; found: boolean; ingredients: Ingredient[];
  }
  const products = productsRaw as Product[];

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;

  const urlInput = $<HTMLInputElement>('pdf-url');
  const loadUrlBtn = $<HTMLButtonElement>('load-url');
  const fileInput = $<HTMLInputElement>('file-input');
  const dropzone = $<HTMLDivElement>('dropzone');
  const statusEl = $<HTMLDivElement>('status');
  const results = $<HTMLElement>('results');
  const rows = $<HTMLTableSectionElement>('rows');
  const bar = $<HTMLDivElement>('bar');
  const legend = $<HTMLDivElement>('legend');
  const count = $<HTMLSpanElement>('count');
  const searchInput = $<HTMLInputElement>('product-search');
  const searchResults = $<HTMLUListElement>('search-results');

  const PALETTE = ['#c8f23a', '#ffb53d', '#56d6d0', '#ff6f91', '#a98bff', '#5aa9ff', '#7ee787', '#ff9b54', '#36c5a8', '#f178b6'];

  function setStatus(msg: string, kind: 'info' | 'err' = 'info') {
    statusEl.textContent = msg;
    statusEl.className = `status ${kind}`;
    statusEl.classList.toggle('hidden', !msg);
  }

  function rangeText(i: Ingredient): string {
    if (i.isProprietary) return 'Proprietary';
    if (i.min === null || i.max === null) return i.concentrationRaw || 'Not stated';
    if (i.min === i.max) return `${i.min}%`;
    return `${i.min}–${i.max}%`;
  }

  function setActive(idx: number, on: boolean) {
    const seg = bar.querySelector<HTMLElement>(`.seg[data-i="${idx}"]`);
    const tr = rows.querySelector<HTMLElement>(`tr[data-i="${idx}"]`);
    seg?.classList.toggle('active', on);
    tr?.classList.toggle('active', on);
    bar.classList.toggle('dimmed', on);
  }

  function render(ingredients: Ingredient[]) {
    rows.innerHTML = '';
    bar.innerHTML = '';
    legend.innerHTML = '';
    count.textContent = `· ${ingredients.length} ingredient${ingredients.length === 1 ? '' : 's'}`;

    ingredients.forEach((ing, idx) => {
      const color = PALETTE[idx % PALETTE.length];

      const tr = document.createElement('tr');
      tr.dataset.i = String(idx);
      tr.style.setProperty('--i', String(idx));
      const propTag = ing.isProprietary ? '<span class="tag">proprietary</span>' : '';
      tr.innerHTML =
        `<td><span class="chem"><span class="dot" style="background:${color}"></span>${escapeHtml(ing.name)}${propTag}</span></td>` +
        `<td class="cas">${escapeHtml(ing.cas || '—')}</td>` +
        `<td class="range">${escapeHtml(rangeText(ing))}</td>` +
        `<td class="num"><span class="est">${ing.estimatedPct}%` +
        `<span class="micro" style="width:${Math.max(2, ing.estimatedPct)}%;background:${color}"></span></span></td>`;
      tr.addEventListener('mouseenter', () => setActive(idx, true));
      tr.addEventListener('mouseleave', () => setActive(idx, false));
      rows.appendChild(tr);

      if (ing.estimatedPct > 0) {
        const seg = document.createElement('div');
        seg.className = 'seg';
        seg.dataset.i = String(idx);
        seg.style.width = `${ing.estimatedPct}%`;
        seg.style.background = color;
        seg.style.setProperty('--i', String(idx));
        seg.title = `${ing.name} · ${ing.estimatedPct}%`;
        seg.addEventListener('mouseenter', () => setActive(idx, true));
        seg.addEventListener('mouseleave', () => setActive(idx, false));
        bar.appendChild(seg);
      }

      const item = document.createElement('span');
      item.innerHTML = `<span class="dot" style="background:${color}"></span>${escapeHtml(ing.name)} (${ing.estimatedPct}%)`;
      legend.appendChild(item);
    });

    results.classList.remove('hidden');
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));
  }

  // ----- product catalog search (baked-in dataset) -----
  function searchProducts(q: string): Product[] {
    const t = q.trim().toLowerCase();
    if (!t) return [];
    const tokens = t.split(/\s+/);
    return products
      .filter((p) => {
        const hay = [p.name, p.brand ?? '', ...(p.aliases ?? []), ...p.ingredients.map((i) => i.name)]
          .join(' ')
          .toLowerCase();
        return tokens.every((tok) => hay.includes(tok));
      })
      .slice(0, 8);
  }

  function renderResults(list: Product[]) {
    searchResults.innerHTML = '';
    if (list.length === 0) { searchResults.classList.add('hidden'); return; }
    list.forEach((p) => {
      const li = document.createElement('li');
      const top = p.ingredients[0];
      li.innerHTML =
        `<span class="r-name">${escapeHtml(p.name)}</span>` +
        `<span class="r-meta">${p.ingredients.length} ingredients` +
        `${top ? ` · ${escapeHtml(top.name)} ${top.estimatedPct}%` : ''}</span>`;
      li.addEventListener('click', () => selectProduct(p));
      searchResults.appendChild(li);
    });
    searchResults.classList.remove('hidden');
  }

  function selectProduct(p: Product) {
    searchInput.value = p.name;
    searchResults.classList.add('hidden');
    setStatus(`${p.name}${p.sourceUrl ? ' · from saved SDS' : ''}`);
    render(p.ingredients);
  }

  searchInput.addEventListener('input', () => renderResults(searchProducts(searchInput.value)));
  searchInput.addEventListener('focus', () => {
    if (searchInput.value) renderResults(searchProducts(searchInput.value));
  });
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const r = searchProducts(searchInput.value);
      if (r[0]) selectProduct(r[0]);
    }
  });
  document.addEventListener('click', (e) => {
    if (!searchResults.contains(e.target as Node) && e.target !== searchInput) {
      searchResults.classList.add('hidden');
    }
  });

  async function analyze(data: ArrayBuffer, label: string) {
    try {
      setStatus(`Reading ${label}…`);
      const lines = await extractLines(data);
      const comp = parseSds(lines);
      if (!comp.found) {
        setStatus('Could not locate Section 3 (Composition) in this PDF. Is it a standard SDS?', 'err');
        results.classList.add('hidden');
        return;
      }
      if (comp.ingredients.length === 0) {
        setStatus('Section 3 was found but no ingredients/CAS numbers could be parsed.', 'err');
        results.classList.add('hidden');
        return;
      }
      setStatus(`Parsed ${comp.ingredients.length} ingredient(s) from Section 3.`);
      render(comp.ingredients);
    } catch (err) {
      console.error(err);
      setStatus(`Failed to read the PDF: ${(err as Error).message}`, 'err');
    }
  }

  // File upload / drag-drop
  dropzone.addEventListener('click', () => fileInput.click());
  ['dragover', 'dragenter'].forEach((e) =>
    dropzone.addEventListener(e, (ev) => { ev.preventDefault(); dropzone.classList.add('drag'); }),
  );
  ['dragleave', 'drop'].forEach((e) =>
    dropzone.addEventListener(e, () => dropzone.classList.remove('drag')),
  );
  dropzone.addEventListener('drop', (ev) => {
    ev.preventDefault();
    const file = ev.dataTransfer?.files?.[0];
    if (file) handleFile(file);
  });
  fileInput.addEventListener('change', () => {
    const file = fileInput.files?.[0];
    if (file) handleFile(file);
  });

  async function handleFile(file: File) {
    if (!/\.pdf$/i.test(file.name) && file.type !== 'application/pdf') {
      setStatus('Please choose a PDF file.', 'err');
      return;
    }
    analyze(await file.arrayBuffer(), file.name);
  }

  // URL fetch: direct PDF link or a product page we dig the SDS link out of.
  // Cross-origin requests route through a public CORS proxy (see lib/source).
  async function loadFromUrl() {
    const url = urlInput.value.trim();
    if (!url) { setStatus('Paste a Home Depot product link or an SDS PDF link first.', 'err'); return; }
    loadUrlBtn.disabled = true;
    try {
      setStatus('Resolving link…');
      const { bytes, sourceUrl, fromPage } = await resolveToPdf(url);
      if (fromPage) setStatus(`Found SDS: ${sourceUrl}`);
      await analyze(bytes, fromPage ? 'found SDS' : 'linked PDF');
    } catch (err) {
      setStatus((err as Error).message || 'Could not load that link.', 'err');
    } finally {
      loadUrlBtn.disabled = false;
    }
  }

  loadUrlBtn.addEventListener('click', loadFromUrl);
  urlInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') loadFromUrl(); });
</script>
