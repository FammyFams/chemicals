---
import '../styles/global.css';
interface Props { title?: string }
const { title = 'SDS Composition Analyzer' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Read a product's Safety Data Sheet and break down its chemical composition by percent." />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ctext y='14' font-size='14'%3E%E2%9A%97%EF%B8%8F%3C/text%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>

    <header class="site">
      <div class="wrap">
        <div class="instrument-bar">
          <span class="readout">
            <span class="led" aria-hidden="true"></span>SDS&nbsp;ANALYZER
          </span>
          <span class="readout dim">OFFLINE&nbsp;PARSER</span>
          <span class="readout dim">PDF&nbsp;·&nbsp;SECTION&nbsp;3</span>
          <span class="readout ver">v0.1</span>
        </div>

        <div class="masthead">
          <svg class="diamond" viewBox="0 0 100 100" aria-hidden="true">
            <rect x="20" y="20" width="60" height="60" transform="rotate(45 50 50)"
              fill="none" stroke="currentColor" stroke-width="3" />
            <line x1="50" y1="6" x2="50" y2="50" stroke="currentColor" stroke-width="2" opacity=".4" />
          </svg>
          <div>
            <h1>Composition<span class="brk"></span><em>Analyzer</em></h1>
            <p class="tagline">
              Feed it a Safety Data Sheet — get the chemical breakdown, by percent.
            </p>
          </div>
        </div>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site">
      <span class="rule" aria-hidden="true"></span>
      Estimates derive from disclosed SDS ranges and the assumption that components total&nbsp;~100%.
      Not a substitute for the official Safety Data Sheet.
    </footer>
  </body>
</html>
