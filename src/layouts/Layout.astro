---
import '../styles/global.css';
interface Props { title?: string }
const { title = 'SDS Composition Finder' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Read a product's Safety Data Sheet and break down the chemical composition by percent." />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Ctext y='14' font-size='14'%3E%E2%9A%97%EF%B8%8F%3C/text%3E%3C/svg%3E" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <h1><span class="accent">SDS</span> Composition Finder</h1>
        <p class="tagline">Drop in a Safety Data Sheet PDF and see the chemical breakdown by percent.</p>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="site">
      Estimates are derived from disclosed SDS ranges and the assumption that components total ~100%. Not a substitute for the official SDS.
    </footer>
  </body>
</html>
